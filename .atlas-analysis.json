  "publicApiSurface": [
    "/auth/pages/login - User authentication",
    "/home/pages/index - Public homepage",
    "/home/pages/start - Admin dashboard",
    "/animals/pages/allanimals - Browse all animals",
    "/animals/pages/animalpicked?id={id} - View individual animal",
    "/animals/feeding/* - Animal feeding logs (authenticated)",
    "/animals/gest/* - Animal management (authenticated)",
    "/habitats/pages/* - Habitat browsing",
    "/habitats/gest/* - Habitat management (authenticated)",
    "/contact/pages/contact - Contact form",
    "/testimonials/pages/* - Visitor testimonials",
    "/vreports/* - Veterinary health reports (authenticated)",
    "/users/gest/* - User management (admin only)",
    "/roles/gest/* - Role management (admin only)",
    "/permissions/gest/* - Permission management (admin only)"
  ]
